% ----- Rules -----

% Father and Mother
father(X, Y) :-
    parent(X, Y),
    male(X).

mother(X, Y) :-
    parent(X, Y),
    female(X).

% Siblings
brother(X, Y) :-
    parent(Z, X),
    parent(Z, Y),
    male(X),
    X \== Y.

sister(X, Y) :-
    parent(Z, X),
    parent(Z, Y),
    female(X),
    X \== Y.

siblings(X, Y) :-
    (brother(X, Y); sister(X, Y)),
    X \== Y.

% Grandparents
grandfather(X, Z) :-
    father(X, Y),
    parent(Y, Z).

grandmother(X, Z) :-
    mother(X, Y),
    parent(Y, Z).

% Uncle and Aunt
uncle(X, Y) :-
    parent(Z, Y),
    brother(X, Z).

aunt(X, Y) :-
    parent(Z, Y),
    sister(X, Z).

% Cousins
cousin(X, Y) :-
    parent(A, X),
    parent(B, Y),
    siblings(A, B).

% Nephew and Niece
nephew(X, Y) :-
    male(X),
    parent(Z, X),
    siblings(Z, Y).

niece(X, Y) :-
    female(X),
    parent(Z, X),
    siblings(Z, Y).


